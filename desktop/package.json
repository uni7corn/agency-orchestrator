{
  "name": "agency-orchestrator-desktop",
  "private": true,
  "version": "0.3.0",
  "description": "Agency Orchestrator — desktop app (Electron)",
  "main": "main.cjs",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.jnmetacode.agency-orchestrator",
    "productName": "Agency Orchestrator",
    "afterSign": "scripts/afterSign.cjs",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.cjs"
    ],
    "npmRebuild": false,
    "extraResources": [
      {
        "from": "../web",
        "to": "app/web"
      },
      {
        "from": "../website/dist",
        "to": "app/website/dist"
      },
      {
        "from": "../dist",
        "to": "app/dist"
      },
      {
        "from": "../workflows",
        "to": "app/workflows"
      },
      {
        "from": "../package.json",
        "to": "app/package.json"
      },
      {
        "from": "../node_modules",
        "to": "app/node_modules"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "identity": null
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        "AppImage"
      ]
    }
  }
}
